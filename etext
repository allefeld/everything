  local pn="$1"
  local out="$cn.tmp"   # already in cache directory
  log "calling: exiftool"
  exiftool \
    -p '---' \
    -p 'image.size: $ImageSize' \
    -p 'animation.iterations: $AnimationIterations' \
    -p 'frame.count: $FrameCount' \
    -p 'duration: $Duration' \
    -p 'title: "$Title"' \
    -p 'creator: "$Creator"' \
    -p 'date: $Date' \
    -p 'subject: "$Subject"' \
    -p 'catalog.sets: "$CatalogSets"' \
    -p 'hierarchical.subject: "$HierarchicalSubject"' \
    -p 'last.keyword: "$LastKeywordXMP"' \
    -p 'tags.list: "$TagsList"' \
    -p '---$/' \
    -p '#[BODY]# Description $/$/$Description$/' \
    -p '#[BODY]# Comment$/$/$Comment$/' \
    -p '#[BODY]# Image Description$/$/$ImageDescription$/' \
    -p '#[BODY]# Notes$/$/$Notes$/' \
    -p '#[BODY]# User Comment$/$/$UserComment$/' \
    "$pn" \
    > "$out" 2>&$logfd
  local status=$?
  log "exiting: $status"
  if [[ $status -eq 0 ]]
  then
    # write to & produce from cache
    mv "$out" "$cn"
    produce "$cn"
