}

# handle SVG
function handle_svg {
  log "handle_svg" "$@"
  local pn="$1"
  local out="$cn.tmp"   # already in cache directory
  log "calling: exiftool"
  exiftool \
    -p '---' \
    -p 'image.width: $ImageWidth' \
    -p 'image.height: $ImageHeight' \
    -p 'view.box: $ViewBox' \
    -p 'title: $WorkTitle' \
    -p 'date: $WorkDate' \
    -p 'creator: $WorkCreatorAgentTitle' \
    -p 'publisher: $WorkPublisherAgentTitle' \
    -p 'source: $WorkSource' \
    -p 'language: $WorkLanguage' \
    -p 'subject: $WorkSubject' \
    -p 'contributor: $WorkContributorAgentTitle' \
    -p '---$/' \
    -p '#[BODY]# Description $/$/$WorkDescription$/' \
    "$pn" \
    > "$out" 2>&$logfd
  local status=$?
  log "exiting: $status"
  if [[ $status -ne 0 ]]
  then
    err $LINENO "exiftool failed on '$pn'"
  fi
  echo "# Text" >> "$out"
  echo >> "$out"
  log "calling: xsltproc"
  xsltproc - "$pn" >> "$out" 2>&$logfd <<'EOF'
<?xml version="1.0"?>
<xsl:stylesheet version="1.0"
  xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
  xmlns:svg="http://www.w3.org/2000/svg">
  <xsl:output method="text"/>
  <xsl:strip-space elements="*"/>
  <xsl:template match="svg:text//text()">
    <xsl:value-of select="normalize-space(.)"/>
    <xsl:text>&#10;</xsl:text>
  </xsl:template>
  <xsl:template match="text()"/>
</xsl:stylesheet>
EOF
  local status=$?
  log "exiting: $status"
  if [[ $status -eq 0 ]]
  then
    # write to & produce from cache
    mv "$out" "$cn"
    produce "$cn"
  else
    log "not handled by xsltproc"
    produce "$pn"
    rm -f "$out"    # delete from cache just in case
    err $LINENO "xsltproc failed on '$pn'"
  fi
}

# handle archive (zip, tar, 7z, rar)
function handle_archive {
  log "handle_archive" "$@"
  local pn="$1"
  local fmt="$2"
  local out="$cn.tmp"
  local fn=$(basename "$pn")
  local status
  local errmsg="archive listing failed on '$pn'"

  {
    echo "---"
    printf 'archive.name: "%s"\n' "$fn"
    echo "archive.format: $fmt"
    echo "---"
    echo
    echo "# Contents"
    echo
    echo '```'
  } > "$out"

  case "$fmt" in
    zip)
      log "calling: unzip"
      # unzip -v: fields are Length Method Size Cmpr Date Time CRC-32 Name
      unzip -v "$pn" 2>&$logfd \
        | awk '$1~/^[0-9]+$/ && NF>=8 {
            crc=$7; name=$8
            for(i=9;i<=NF;i++) name=name" "$i
            print crc "  " name
          }' \
        | sort -k2 >> "$out"
      status=${PIPESTATUS[0]}
      ;;
    tar)
      log "calling: tar"
      tar -tf "$pn" 2>&$logfd | sort >> "$out"
      status=${PIPESTATUS[0]}
      ;;
    7z)
      log "calling: 7z"
      # 7z l -slt: structured listing; emit path+CRC pairs on new Path= or EOF
      7z l -slt "$pn" 2>&$logfd \
        | awk '
            /^----------/{in_files=1; next}
            !in_files{next}
            /^Path = /{if(path && crc) print crc "  " path; path=substr($0,8); crc=""}
            /^CRC = /{crc=substr($0,7)}
            END{if(path && crc) print crc "  " path}
          ' \
        | sort -k2 >> "$out"
      status=${PIPESTATUS[0]}
      ;;
    rar)
      log "calling: unrar"
      # capture stderr to detect solid archive errors while still forwarding to log
      local rar_err
      rar_err=$(mktemp)
      # unrar --list: filename lines start with one space, between the --- separators
      unrar --list "$pn" 2>"$rar_err" \
        | awk '/^---/{in_files=!in_files; next} in_files && /^ [^ ]/{print substr($0,2)}' \
        | sort >> "$out"
      status=${PIPESTATUS[0]}
      cat "$rar_err" >&$logfd
      if [[ $status -ne 0 ]] && grep -qi "solid" "$rar_err"; then
        errmsg="solid RAR archive not supported by unrar-free: '$pn'"
      fi
      rm -f "$rar_err"
      ;;
  esac
  echo '```' >> "$out"
  log "exiting: $status"

  if [[ $status -eq 0 ]]
  then
    mv "$out" "$cn"
    produce "$cn"
  else
    log "not handled"
    produce "$pn"
    rm -f "$out"
    err $LINENO "$errmsg"
  fi
}

# handle compressed
# uncompressed → `handle`
function handle_compressed {
  log "handle_compressed" "$@"
  local pn="$1"
  local tool="$2"
  local tmp=$(mktemp -d)
  ln -s "$pn" "$tmp"
  log "calling: $tool"
  case "$tool" in
    gunzip)
      gunzip --force "$tmp/"* 2>&$logfd
      ;;
    unzstd)
      unzstd --rm --force "$tmp/"* 2>&$logfd
      ;;
    bunzip2)
      bunzip2 --force "$tmp/"* 2>&$logfd
      ;;
  esac
  local status=$?
  log "exiting: $status"
  if [[ $status -eq 0 ]]
  then
    handle "$tmp/"*         # OK
  else
    log "not handled by $tool"
    produce "$pn"
    err $LINENO "$tool failed on '$pn'"
  fi
}

# handle
function handle {
  log "handle" "$@"
  local pn="$1"

  # skip everything that is effectively "empty" or a symlink to it
  if [[ ! -s "$pn" ]]
  then
    # nothing to read, "empty"
    log "(symlink to) special, empty, or non-existing"
    produce "$pn"
    return
  fi

  # extension is dispatch criterion
  local fn=$(basename "$pn")
  local ext="${fn##*.}"
  log "ext: $ext"

  case "${ext,,}" in
    # formats which Pandoc can read
    # <https://pandoc.org/MANUAL.html#general-options>,
    # <https://github.com/jgm/pandoc/blob/main/src/Text/Pandoc/Format.hs#L175>
    docx|epub|fb2|ipynb|odt|rtf)
      handle_pandoc "$pn" "$ext"
      ;;
    html|htm|xhtml|shtml|aspx)
      handle_pandoc "$pn" "html"
      ;;
    tex)
      handle_pandoc "$pn" "latex"
      ;;
    1|2|3|4|5|6|7|8)
      handle_pandoc "$pn" "man"
      ;;
    # PDF
    pdf)
      handle_pdftohtml "$pn"
      ;;
    # PowerPoint 2007+
    pptx)
      handle_pptx2md "$pn"
      ;;
    # formats which Calibre's `ebook-convert` can convert
    # <https://manual.calibre-ebook.com/generated/en/ebook-convert.html>
    mobi|chm|djvu|djv|prc|azw|azw3|azw4|lit|lrf|pdb|pml|rb|snb|tcr)
      handle_calibre "$pn"
      ;;
    # document formats which LibreOffice can convert to docx
    # <https://books.libreoffice.org/en/GS74/GS7410-FileFormatsSecurityExporting.html#toc6>
    doc|fodt|wps|abw|zabw|mw|mcw|602|pages|wpd|wp| \
    lwp|cwk|sdw|sgl|vor|uot|uof|hwp|sxw|stw|sxg)
      handle_libreoffice_document "$pn" "$ext"
      ;;
    # presentation formats which LibreOffice can convert to pptx
    # <https://books.libreoffice.org/en/GS74/GS7410-FileFormatsSecurityExporting.html#toc6>
    ppt|odp|fodp|sdp|sxi|uop|uof|key)
      handle_libreoffice_presentation "$pn" "$ext"
      ;;
    # audio formats which ExifTool can read
    flac|mp3|m4a|ogg|mka|opus|aiff|wav)
      handle_audio "$pn"
      ;;
    # image formats which ExifTool can read
    jpg|jpeg|png|gif|webp)
      handle_image "$pn"
      ;;
    # SVG
    svg)
      handle_svg "$pn"
      ;;
    # archive formats
    zip|jar|war|ear|cbz)
      handle_archive "$pn" zip
      ;;
    tar|tgz|taz|tbz2|tbz|txz|tzst|cbt)
      handle_archive "$pn" tar
      ;;
    7z|cb7)
      handle_archive "$pn" 7z
      ;;
    rar|cbr)
      handle_archive "$pn" rar
      ;;
    # compressed single-file formats
    gz|z)
      handle_compressed "$pn" "gunzip"
      ;;
    zstd|xz|lzma|lz4)
      handle_compressed "$pn" "unzstd"
      ;;
    bz2|bz)
      handle_compressed "$pn" "bunzip2"
      ;;
    # unknown format
    *)
      log "unknown format"
      produce "$pn"
      ;;
  esac
}


# main code –––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––

# cache dir
cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/everything"
mkdir -p "$cache_dir"

# usage message and prune cache
if [ $# -eq 0 ]
then
  echo
  echo "Usage: etext FILENAME"
  echo "       etext FILENAME --filename"
  echo "       etext"
  echo
  echo "The first syntax prints a textual representation of the file contents,"
  echo "if possible. Representations are cached in '$cache_dir'."
  echo "The second syntax writes the textual representation into a file and"
  echo "prints the filename. This is used by \`ecolor\`."
  echo "The third syntax prints this message and prunes the cache."
  echo
  echo "Pruning cache"
  find "$cache_dir" -type f -atime +30 -delete
  rm -f "$cache_dir"/*.tmp
  c=$(find "$cache_dir" -type f | wc -l)
  echo "$c cache entries remain"
  echo
  exit 0
fi

# pathname
pn=$(realpath --no-symlinks "$1")
# `--no-symlinks` → use extension of symlink, not target

# output type
if [[ "$2" == "--filename" ]]
then
  # used by ecolor
  function produce {
    log "producing filename $1"
    echo "$1"
  }
else
  # used by rg
  function produce {
    log "producing contents of $1"
    cat "$1"
  }
fi

# cache file name
hash=$(echo "$pn" | b2sum -l 128 | cut -b 1-32)
log "hash: $hash"
# assumes all cached content is Markdown
cn="$cache_dir/$hash.md"

# check cache
if [[ -e "$cn" && "$cn" -nt "$pn" ]]; then
  produce "$cn"
  exit 0
fi

# handle
handle "$pn"
